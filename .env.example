# Copy to .env.local and fill in. Netlify injects NETLIFY_DATABASE_URL automatically in deploys.

# Anthropic Claude API key (Sonnet 4.6 + Opus 4.7)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI key (voyage-3-large, 1024d)
VOYAGE_API_KEY=pa-...

# Netlify DB (Neon Postgres). Locally: get from `netlify env:get NETLIFY_DATABASE_URL`.
NETLIFY_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Optional dev knobs
KURSU_DEMO_TEACHER_ID=teacher_demo_001
KURSU_LOG_LEVEL=info

# Post-lecture report email (Resend). If RESEND_API_KEY is unset, the email step is skipped.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Kürsü <reports@kursu.app>
REPORT_EMAIL_TO=teacher@example.com

# Local frontend mock mode. Use true only when you want to run Vite without Netlify/DB.
VITE_MOCK_API=false
